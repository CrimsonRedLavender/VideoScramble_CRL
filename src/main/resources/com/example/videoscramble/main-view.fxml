<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.videoscramble.MainController">

    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <Label text="VideoScramble - version finale JavaFX + OpenCV" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="100" prefWidth="100"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                    <ColumnConstraints minWidth="100" prefWidth="100"/>
                    <ColumnConstraints minWidth="100" prefWidth="100"/>
                    <ColumnConstraints minWidth="130" prefWidth="130"/>
                </columnConstraints>

                <Label text="Entrée" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="inputField" promptText="Vidéo d'entrée" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Button text="Parcourir" onAction="#browseInput" GridPane.rowIndex="0" GridPane.columnIndex="2"/>

                <Label text="Sortie" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="outputField" promptText="Vidéo de sortie, ou image .png pour le cassage" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <Button text="Parcourir" onAction="#browseOutput" GridPane.rowIndex="1" GridPane.columnIndex="2"/>

                <Label text="Offset r" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                <TextField fx:id="offsetField" onKeyReleased="#updateKeyLabel" GridPane.rowIndex="0" GridPane.columnIndex="4"/>

                <Label text="Step s" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                <TextField fx:id="stepField" onKeyReleased="#updateKeyLabel" GridPane.rowIndex="1" GridPane.columnIndex="4"/>
            </GridPane>

            <HBox spacing="10">
                <Button fx:id="encryptButton" text="Chiffrer la vidéo" onAction="#encrypt"/>
                <Button fx:id="decryptButton" text="Déchiffrer la vidéo" onAction="#decrypt"/>
                <Button fx:id="crackImageButton" text="Casser la clé" onAction="#crackImage"/>
                <Button text="Enregistrer la clé" onAction="#saveKeyToText"/>
                <Button text="Charger la clé" onAction="#loadKeyFromText"/>
                <CheckBox fx:id="showPreviewCheckBox" text="Afficher l'aperçu"/>
                <CheckBox fx:id="embedKeyCheckBox" text="Embarquer clé"/>
                <CheckBox fx:id="readEmbeddedKeyCheckBox" text="Lire clé embarquée"/>
                <CheckBox fx:id="changeKeyCheckBox" text="Changer clé"/>
                <TextField fx:id="keyChangeIntervalField" prefWidth="70" promptText="100"/>
                <Label text="Score"/>
                <ComboBox fx:id="scoreCombo" prefWidth="140"/>
            </HBox>

            <VBox spacing="4">
                <TextField fx:id="keyLabel" text="Clé :" editable="false"/>
                <TextField fx:id="blocksLabel" text="Blocs :" editable="false"/>
                <TextField fx:id="statusLabel" text="Prêt." editable="false"/>
            </VBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="12">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Entrée"/>
                <ImageView fx:id="sourceView" fitWidth="600" fitHeight="500" preserveRatio="true"/>
            </VBox>
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Résultat"/>
                <ImageView fx:id="resultView" fitWidth="600" fitHeight="500" preserveRatio="true"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
